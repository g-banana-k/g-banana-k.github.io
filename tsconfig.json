{
    "compilerOptions": {
        "module": "ES2022",
        "target": "ES2022",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "baseUrl": "./src",
        "paths": {
            "~/*": ["*"]
        },
        "jsxImportSource": "~/syzygy/jsx",
        "jsx": "react-jsx"
    },
    "include": ["src/**/*"]
}
